# ============================================
# StartupX AI — Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================

# --- ANTHROPIC (REQUIRED) ---
# Get from: https://console.anthropic.com/
# Used server-side ONLY in API routes — never exposed to browser
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SUPABASE (REQUIRED for DB persistence) ---
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- APP CONFIG (REQUIRED) ---
NEXT_PUBLIC_APP_URL=https://startupxai.com
# For local dev use: http://localhost:3000

# --- SECURITY ---
# Random string for IP hashing (generate with: openssl rand -hex 32)
IP_HASH_SALT=your-random-salt-string-here-min-32-chars

# --- NODE ENV ---
NODE_ENV=development
# Set to 'production' on deployment

# ============================================
# NOTES:
# - All NEXT_PUBLIC_ vars are exposed to the browser
# - All other vars are server-side only
# - Rotate ANTHROPIC_API_KEY if compromised
# - Never share SUPABASE_SERVICE_ROLE_KEY
# ============================================
